EBIBLE_DATA_DIR=C:\ebible_data_pipeline
CORPUS_PATH=C:\ebible_data_pipeline\corpus
MAX_AGE_DAYS=565
LOG_LEVEL=WARNING

TEST_EBIBLE_DATA_DIR=C:\ebible_data_test

VREF_FILENAME=vref.txt
METADATA_FILENAME=ebible_status.csv
HUGGINGFACE_OUTPUT_FOLDER=huggingface
HUGGINGFACE_MAIN_PARQUET_FILENAME=main.parquet
HUGGINGFACE_METADATA_PARQUET_FILENAME=metadata.parquet

# Corpus content validation thresholds
# MINIMUM_LINES_IN_EXTRACT: a translation is excluded if fewer than this many lines contain data
# MINIMUM_CHARACTERS_IN_VERSE: lines with fewer characters than this value are not counted as
#   containing data (used only for the minimum_lines_in_extract check, not for line-count validation)
MINIMUM_LINES_IN_EXTRACT=400
MINIMUM_CHARACTERS_IN_VERSE=7